// KeiPix release metadata.
//
// MARKETING_VERSION maps to CFBundleShortVersionString and must stay in
// x.y.z form. CURRENT_PROJECT_VERSION maps to CFBundleVersion and should
// increase for every distributable build of the same marketing version.
// Dotted build components after the first must fit 0...999 so scripts can
// derive a stable integer versionCode for LiveContainer source metadata.
MARKETING_VERSION = 0.1.0
CURRENT_PROJECT_VERSION = 1
