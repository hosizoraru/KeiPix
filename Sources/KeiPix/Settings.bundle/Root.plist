<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>PreferenceSpecifiers</key>
    <array>
        <dict>
            <key>Type</key>
            <string>PSGroupSpecifier</string>
            <key>Title</key>
            <string>Recovery</string>
            <key>FooterText</key>
            <string>Turn this on if KeiPix crashes before its settings screen opens. The next launch clears regenerable caches, then turns this switch off. Account sessions, downloads, bookmarks, muted content, and subscriptions are kept.</string>
        </dict>
        <dict>
            <key>Type</key>
            <string>PSToggleSwitchSpecifier</string>
            <key>Title</key>
            <string>Clear Caches on Next Launch</string>
            <key>Key</key>
            <string>clearCachesOnNextLaunch</string>
            <key>DefaultValue</key>
            <false/>
        </dict>
    </array>
    <key>StringsTable</key>
    <string>Root</string>
</dict>
</plist>
