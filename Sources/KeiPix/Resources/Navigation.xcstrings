  "strings": {
    "Choose the routes that appear in the iPad portrait shortcut menu. iPhone keeps its compact bottom tabs.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose the routes that appear in the iPad portrait shortcut menu. iPhone keeps its compact bottom tabs."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "iPad縦向きのショートカットメニューに表示する項目を選びます。iPhoneはコンパクトな下部タブを維持します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择显示在 iPad 竖屏快捷菜单里的入口。iPhone 会继续使用紧凑底栏。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "選擇顯示在 iPad 直向快捷選單裡的入口。iPhone 會繼續使用精簡底欄。"
          }
        }
      }
    },
