    "When switching tabs, return to the last page used in that tab. Turn this off to always open the default page.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When switching tabs, return to the last page used in that tab. Turn this off to always open the default page."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "タブを切り替えたとき、そのタブで最後に使ったページへ戻ります。オフにすると常に既定ページを開きます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "切换底栏标签时回到该标签上次使用的页面。关闭后每次都会打开默认页面。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "切換底欄標籤時回到該標籤上次使用的頁面。關閉後每次都會開啟預設頁面。"
          }
        }
      }
    },
