    "Remember Each Tab's Last Page": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Remember Each Tab's Last Page"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "各タブの最後のページを記憶"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "记住每个标签的上次页面"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "記住每個標籤的上次頁面"
          }
        }
