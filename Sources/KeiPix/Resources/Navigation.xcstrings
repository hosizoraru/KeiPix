    "Choose the three destinations that stay next to Feed and Search on iPhone and iPad portrait.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose the three destinations that stay next to Feed and Search on iPhone and iPad portrait."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "iPhoneとiPad縦向きでフィードと検索の横に固定表示する3つの移動先を選びます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择 iPhone 和 iPad 竖屏上固定显示在作品流与搜索旁边的三个入口。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "選擇 iPhone 和 iPad 直向上固定顯示在作品流與搜尋旁邊的三個入口。"
          }
        }
      }
    },
    "Choose the default page for each iPhone and iPad portrait tab.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose the default page for each iPhone and iPad portrait tab."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "iPhoneとiPad縦向きで、各タブを開いたときの既定ページを選びます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择 iPhone 和 iPad 竖屏中每个底栏标签默认打开的页面。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "選擇 iPhone 和 iPad 直向中每個底欄標籤預設開啟的頁面。"
          }
        }
      }
    },
    "Choose which tab iPhone and iPad portrait should open after a cold start.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose which tab iPhone and iPad portrait should open after a cold start."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "iPhoneとiPad縦向きで、コールドスタート後に開くタブを選びます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择 iPhone 和 iPad 竖屏冷启动后默认打开的底栏标签。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "選擇 iPhone 和 iPad 直向冷啟動後預設開啟的底欄標籤。"
          }
        }
      }
    },
