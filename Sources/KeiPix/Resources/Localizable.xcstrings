    "OSLogStore couldn't be opened. This usually means the app needs to be relaunched after install or that the system log database is sealed.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "OSLogStore couldn't be opened. This usually means the app needs to be relaunched after install or that the system log database is sealed."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "OSLogStore を開けませんでした。通常はインストール後の再起動が必要か、システムログのデータベースがシールされています。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法打开 OSLogStore。通常意味着 App 安装后需要重启，或系统日志数据库已封存。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "無法開啟 OSLogStore。通常意味著 App 安裝後需要重新啟動，或系統日誌資料庫已封存。"
          }
        }
      }
