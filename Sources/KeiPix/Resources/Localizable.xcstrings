          }
        }
      }
    },
    "Cards from artists the user follows pick up an accent border and a Following badge in mixed feeds, and the toggle round-trips through UserDefaults.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cards from artists the user follows pick up an accent border and a Following badge in mixed feeds, and the toggle round-trips through UserDefaults."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "混在フィードで、フォロー中の絵師の作品にアクセント枠と「フォロー中」バッジを表示し、設定は UserDefaults に保持されます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已关注画师的作品在混合 feed 中呈现强调色边框与「已关注」徽标，开关状态通过 UserDefaults 持久化。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "已追蹤畫师的作品在混合 feed 中呈現强調色邊框與「已追蹤」徽標，開關狀態通過 UserDefaults 持久化。"
          }
        }
      }
    },
    "Catalog covers every ShortcutAction case, surfaces are well-formed, and System Settings deep-link URL parses in the unit suite.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Catalog covers every ShortcutAction case, surfaces are well-formed, and System Settings deep-link URL parses in the unit suite."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "カタログはすべての ShortcutAction ケースを網羅し、サーフェスは適切に構成され、システム設定へのディープリンク URL もユニットテストで正しく解釈されます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "目录覆盖每一个 ShortcutAction 分支，分组结构完整，且系统设置深链 URL 在单元测试中可正常解析。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "目錄覆盖每一個 ShortcutAction 分支，分組結構完整，且系統設定深鏈 URL 在單元測試中可正常解析。"
          }
        }
      }
    },
