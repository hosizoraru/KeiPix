    "Index downloaded artworks in Spotlight": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Index downloaded artworks in Spotlight"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ダウンロード済み作品を Spotlight でインデックス化"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在 Spotlight 中索引已下载作品"
          }
        },
        "zh-Hant": {
