    "Backup & Restore": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Backup & Restore"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "バックアップと復元"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "备份与恢复"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "備份與還原"
          }
        }
      }
    },
    "Export every locally-stored library — saved searches, browsing history, pinned creators, reader progress, manga read state, muted content, and the bookmark/follow defaults you've tuned — into one JSON file. Importing merges back into the running session without overwriting bits that already exist.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Export every locally-stored library — saved searches, browsing history, pinned creators, reader progress, manga read state, muted content, and the bookmark/follow defaults you've tuned — into one JSON file. Importing merges back into the running session without overwriting bits that already exist."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ローカルに保存されているすべてのライブラリ（保存した検索、閲覧履歴、ピン留めしたクリエイター、リーダーの進捗、マンガの既読状態、ミュートされたコンテンツ、ブックマーク/フォローのデフォルト）を 1 つの JSON ファイルにエクスポートします。インポート時には既存のデータを上書きせず、現在のセッションにマージされます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将本地存储的所有库 — 包括保存的搜索、浏览历史、置顶画师、阅读进度、漫画已读状态、屏蔽内容以及你调整过的收藏/关注默认设置 — 导出为一个 JSON 文件。导入时会合并到当前会话中，不会覆盖已有的内容。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "將本機儲存的所有資料庫 — 包含已儲存的搜尋、瀏覽紀錄、置頂繪師、閱讀進度、漫畫已讀狀態、靜音內容以及你調整過的收藏／追蹤預設值 — 匯出為一個 JSON 檔案。匯入時會合併到目前的工作階段中，不會覆蓋既有的內容。"
          }
        }
      }
    },
