    "Bookmark-date filters use Pixiv Web / Premium. Artwork tags are filtered locally from loaded works.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bookmark-date filters use Pixiv Web / Premium. Artwork tags are filtered locally from loaded works."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ブックマーク日時フィルターは Pixiv Web / Premium を使用します。作品タグは読み込み済み作品からローカルで絞り込みます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "收藏时间筛选使用 Pixiv Web / Premium；作品标签会基于已加载作品在本地筛选。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "收藏時間篩選使用 Pixiv Web / Premium；作品標籤會基於已載入作品在本地篩選。"
          }
        }
      }
    },
    "Collections are currently exposed by Pixiv Web. Open the web tab to browse or manage them.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Collections are currently exposed by Pixiv Web. Open the web tab to browse or manage them."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "コレクションは現在 Pixiv Web で提供されています。Web ページを開いて閲覧または管理してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "珍藏册目前由 Pixiv Web 提供。打开 Web 页面浏览或管理。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "珍藏冊目前由 Pixiv Web 提供。開啟 Web 頁面瀏覽或管理。"
          }
        }
      }
    },
    "Discover user-created Pixiv collections here. You can also paste a collection link to open it natively.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Discover user-created collections here. You can also paste a collection link to open it natively."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ユーザーが作成したコレクションをここで見つけられます。コレクションリンクを貼り付けてネイティブ表示で開くこともできます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在这里发现用户创建的珍藏册。你也可以粘贴珍藏册链接，用原生界面打开。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在這裡發現使用者建立的珍藏冊。你也可以貼上珍藏冊連結，用原生介面開啟。"
          }
        }
      }
    },
    "Collections you publish on Pixiv Web appear here. Paste a collection link to open it natively.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Collections you publish on Pixiv Web appear here. Paste a collection link to open it natively."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Pixiv Webで公開したコレクションがここに表示されます。コレクションリンクを貼り付けてネイティブ表示で開けます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你在 Pixiv Web 发布的珍藏册会显示在这里。也可以粘贴珍藏册链接，用原生界面打开。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你在 Pixiv Web 發布的珍藏冊會顯示在這裡。也可以貼上珍藏冊連結，用原生介面開啟。"
          }
        }
      }
    },
    "Bookmarked Pixiv collections appear here. Use Pixiv Collections discovery or Pixiv Web to save collections.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bookmarked collections appear here. Use Collections discovery or Pixiv Web to save collections."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ブックマークしたコレクションがここに表示されます。コレクションの発見ページまたはPixiv Webで保存できます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "收藏过的珍藏册会显示在这里。可以在珍藏册发现页或 Pixiv Web 中收藏。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "收藏過的珍藏冊會顯示在這裡。可以在珍藏冊發現頁或 Pixiv Web 中收藏。"
          }
        }
      }
    },
    "Pixiv keeps bookmarked collections behind the Web session. KeiPix can open collection links now, but syncing this list needs an explicit Pixiv Web session connection.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pixiv keeps bookmarked collections behind the Web session. KeiPix can open collection links now, but syncing this list needs an explicit Pixiv Web session connection."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ブックマークしたコレクションはPixiv Webセッションの内側にあります。KeiPixはコレクションリンクを開けますが、この一覧の同期には明示的なPixiv Webセッション接続が必要です。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Pixiv 将收藏的珍藏册放在 Web 会话里。KeiPix 现在可以打开珍藏册链接，但同步这个列表需要你明确连接 Pixiv Web 会话。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Pixiv 將收藏的珍藏冊放在 Web 會話裡。KeiPix 現在可以開啟珍藏冊連結，但同步這個列表需要你明確連接 Pixiv Web 會話。"
          }
        }
      }
    },
