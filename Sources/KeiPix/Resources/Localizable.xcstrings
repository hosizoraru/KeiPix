    "Apple's system translation sheet stays reachable on artwork captions and comments, gated to skip empty / emoji-only text.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple's system translation sheet stays reachable on artwork captions and comments, gated to skip empty / emoji-only text."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "作品キャプションとコメントから Apple の翻訳シートにアクセスでき、空文や絵文字のみの文はスキップします。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在作品简介与评论中保留 Apple 系统翻译面板入口，并跳过空文本与纯表情。"
          }
