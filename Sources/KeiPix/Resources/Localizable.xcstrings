            "state": "translated",
            "value": "離線 Feed 快照"
          }
        }
      }
    },
    "Recent feed pages saved locally so the app can keep working when the network drops. Cleared snapshots reload the next time the feed comes back online.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Recent feed pages saved locally so the app can keep working when the network drops. Cleared snapshots reload the next time the feed comes back online."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ネットワークが途切れても動作を続けられるよう、最近のフィードページをローカルに保存しています。クリアすると、次回オンラインに戻ったときに再取得します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "本地保存的最近 Feed 页，便于断网时仍可浏览。清除后下次联网会重新加载。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "本機保存的最近 Feed 頁面，斷網時仍可使用。清除後下次連線會重新載入。"
          }
        }
      }
    },
    "Browsing history": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Browsing history"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "閲覧履歴"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "浏览历史"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "瀏覽歷史"
          }
        }
      }
    },
    "Local list of artworks you've opened. Used by the History sidebar entry; clearing wipes that list without affecting Pixiv's server-side history.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Local list of artworks you've opened. Used by the History sidebar entry; clearing wipes that list without affecting Pixiv's server-side history."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "開いた作品のローカル履歴。サイドバーの「履歴」で使われ、クリアしても Pixiv 側の履歴には影響しません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你打开过的作品的本地列表，供侧边栏的“历史”使用。清除仅影响本地列表，不会改动 Pixiv 服务器端的历史。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你開啟過的作品本機清單，供側邊欄「歷史」使用。清除只會影響本機清單，不會改動 Pixiv 伺服器端的歷史。"
          }
        }
      }
    },
    "Recent search queries that surface as suggestions in the search field. Clearing removes the suggestion list; saved searches stay put.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Recent search queries that surface as suggestions in the search field. Clearing removes the suggestion list; saved searches stay put."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "検索フィールドで候補として表示される最近の検索ワード。クリアしても保存済み検索は残ります。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "搜索框中作为候选项出现的最近搜索词。清除仅移除候选列表,保存的搜索保留。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "搜尋欄中作為候選的最近搜尋詞。清除只移除候選清單,已保存的搜尋會保留。"
          }
        }
      }
    },
