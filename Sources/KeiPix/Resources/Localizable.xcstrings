    "Posts a Notification Center banner once a download wraps up — coalesced for batches so a 50-image queue still surfaces a single banner.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Posts a Notification Center banner once a download wraps up — coalesced for batches so a 50-image queue still surfaces a single banner."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ダウンロードが完了すると通知センターにバナーを表示します。バッチダウンロードはまとめられ、50 枚のキューでも 1 件のバナーになります。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "下载完成后向通知中心推送一条横幅，批量下载会合并为单条横幅，避免 50 张图的队列产生 50 条通知。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "下載完成後向通知中心推送一条橫幅，批量下載會合並為單条橫幅，避免 50 张圖的隊列產生 50 条通知。"
          }
        }
      }
    },
    "Press Space to peek the file with Quick Look, just like Finder.": {
      "extractionState": "manual",
