    "When returning to a section, reuse recently loaded content until this interval expires. Manual refresh always reloads immediately.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When returning to a section, reuse recently loaded content until this interval expires. Manual refresh always reloads immediately."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "セクションに戻ったとき、この間隔が切れるまでは読み込み済みの内容を再利用します。手動更新は常にすぐ再読み込みします。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "返回某个板块时，会在过期前复用最近加载的内容；手动刷新始终会立即重新加载。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "返回某個板塊時，會在過期前沿用最近載入的內容；手動刷新一律會立即重新載入。"
          }
        }
