          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "KeiPixはサンドボックス化されたアプリコンテナ内にPixivトークンを保存しネイティブPixivアプリAPIリクエストを使用"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "KeiPix 把 Pixiv token 存放在沙盒化的应用容器内，并通过原生客户端发起 Pixiv app API 请求。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "KeiPix 把 Pixiv token 存放在沙盒化的應用容器內，並通過原生客戶端發起 Pixiv app API 請求。"
          }
        }
      }
    },
