    "Follow creators or refresh after connecting Pixiv Web to see social activity.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Follow creators or refresh after connecting Pixiv Web to see social activity."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "クリエイターをフォローするか、Pixiv Web 接続後に更新すると動向を表示できます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "关注创作者，或连接 Pixiv Web 后刷新以查看动态。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "追蹤創作者，或連接 Pixiv Web 後重新整理以查看動態。"
          }
        }
      }
    },
    "Pixiv activity is a Web-only feed. Connect a Pixiv Web session to load it in KeiPix.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pixiv activity is a Web-only feed. Connect a Pixiv Web session to load it in KeiPix."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Pixiv の動向は Web 専用フィードです。KeiPix で読み込むには Pixiv Web セッションを接続してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Pixiv 动态是 Web 专属信息流。连接 Pixiv Web 会话后即可在 KeiPix 中加载。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Pixiv 動態是 Web 專屬資訊流。連接 Pixiv Web 會話後即可在 KeiPix 中載入。"
          }
        }
      }
    },
