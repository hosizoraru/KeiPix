    "Copy the current Pixiv refresh token so you can paste it into KeiPix on your iPad. Treat it like a password and clear the clipboard after transferring it.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Copy the current Pixiv refresh token so you can paste it into KeiPix on your iPad. Treat it like a password and clear the clipboard after transferring it."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在の Pixiv refresh token をコピーして、iPad の KeiPix に貼り付けられます。パスワードと同じように扱い、転送後はクリップボードを消去してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "复制当前 Pixiv refresh token，便于粘贴到 iPad 上的 KeiPix。请像密码一样保管，迁移完成后清空剪贴板。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "複製目前 Pixiv refresh token，方便貼到 iPad 上的 KeiPix。請像密碼一樣保管，轉移完成後清空剪貼簿。"
          }
        }
      }
    },
