    "Copy a report summary, open Pixiv Web, or apply a local mute without submitting remote reports from KeiPix.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Copy a report summary, open Pixiv Web, or apply a local mute without submitting remote reports from KeiPix."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "レポートサマリーをコピー、Pixiv Webを開く、KeiPixからリモートレポートを送信せずにローカルミュートを適用"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "复制举报摘要、打开 Pixiv Web，或只在本地屏蔽；KeiPix 不提交远端举报。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "複製檢舉摘要、開啟 Pixiv Web，或只在本地封鎖；KeiPix 不提交遠端檢舉。"
          }
        }
      }
    },
