    "DownloadCompletionNotifier coalesces completed-download titles into a single banner per quiescent burst, gated on the user's opt-in toggle and Apple's authorization state.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "DownloadCompletionNotifier coalesces completed-download titles into a single banner per quiescent burst, gated on the user's opt-in toggle and Apple's authorization state."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "DownloadCompletionNotifier は静寂期間ごとに完了したダウンロードのタイトルを 1 件のバナーへ統合し、ユーザーの設定と Apple の権限状態に従って表示します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "DownloadCompletionNotifier 会在静默窗口内合并已完成的下载标题为单条横幅，受用户开关与 Apple 授权状态共同控制。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "DownloadCompletionNotifier 會在静默窗口內合並已完成的下載標題為單条橫幅，受使用者開關與 Apple 授權狀態共同控制。"
          }
        }
      }
    },
