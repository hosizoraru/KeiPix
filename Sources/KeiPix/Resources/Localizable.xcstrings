    "Notification Center declined permission. Re-enable banners for KeiPix in System Settings → Notifications.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Notification Center declined permission. Re-enable banners for KeiPix in System Settings → Notifications."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "通知センターで権限が拒否されました。「システム設定 → 通知」から KeiPix のバナーを再度許可してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "通知中心已拒绝授权。请在「系统设置 → 通知」中为 KeiPix 重新开启横幅通知。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "通知中心已拒绝授權。請在「系統設定 → 通知」中為 KeiPix 重新開啟橫幅通知。"
          }
        }
      }
    },
    "Notifier records every markCompleted call and posts one Notification Center request per debounce window.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Notifier records every markCompleted call and posts one Notification Center request per debounce window."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "通知サービスは markCompleted の呼び出しを記録し、デバウンスウィンドウごとに通知センターへ 1 件のリクエストを送信します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "通知器在每次 markCompleted 调用时记录任务，并在防抖窗口内向通知中心发送一次请求。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "通知器在每次 markCompleted 調用時記錄任务，並在防抖窗口內向通知中心傳送一次請求。"
          }
        }
      }
    },
