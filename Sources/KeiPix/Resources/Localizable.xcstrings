    "High-frequency browsing and reading paths prefer AppKit/UIKit-backed native behavior, with SwiftUI composing the app chrome and settings surfaces.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "High-frequency browsing and reading paths prefer AppKit/UIKit-backed native behavior, with SwiftUI composing the app chrome and settings surfaces."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "高頻度のブラウズと読書の経路では AppKit/UIKit に支えられたネイティブ挙動を優先し、SwiftUI はアプリのクローム、状態、設定画面を構成します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "高频浏览和阅读路径优先采用 AppKit/UIKit 支撑的原生行为，SwiftUI 负责组合应用外壳、状态与设置界面。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "高頻瀏覽與閱讀路徑優先採用 AppKit/UIKit 支撐的原生行為，SwiftUI 負責組合 App 外殼、狀態與設定介面。"
          }
        }
      }
    },
