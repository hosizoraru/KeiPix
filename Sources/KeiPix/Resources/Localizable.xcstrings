    "Decoded thumbnails kept in memory and the on-disk URLCache used by the image pipeline. Re-downloads transparently next time an artwork is viewed.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Decoded thumbnails kept in memory and the on-disk URLCache used by the image pipeline. Re-downloads transparently next time an artwork is viewed."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "メモリにキャッシュされたデコード済みサムネイルと、画像パイプラインが使うディスク上の URLCache。次に作品を開くと自動的に再取得されます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "图像管线使用的内存中已解码缩略图与磁盘 URLCache。下次浏览作品时会自动重新下载。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "影像管線使用的記憶體中已解碼縮圖與磁碟 URLCache。下次瀏覽作品時會自動重新下載。"
          }
        }
      }
    },
    "Offline feed snapshots": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Offline feed snapshots"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オフラインフィードのスナップショット"
          }
        },
        "zh-Hans": {
