    "View runtime diagnostics emitted by KeiPix's subsystem (com.keipix.client). Useful for filing bug reports without leaving the app.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "View runtime diagnostics emitted by KeiPix's subsystem (com.keipix.client). Useful for filing bug reports without leaving the app."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "KeiPix のサブシステム (com.keipix.client) が出力するランタイム診断情報を表示します。アプリを離れずにバグレポートを作成するのに便利です。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "查看 KeiPix 子系统 (com.keipix.client) 在运行时输出的诊断信息。便于在不离开 App 的情况下提交问题报告。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "查看 KeiPix 子系統 (com.keipix.client) 在執行階段輸出的診斷資訊。便於在不離開 App 的情況下提交問題回報。"
