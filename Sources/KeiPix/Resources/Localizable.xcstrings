    "Adds an accent border and a Following badge so artists you follow stand out in mixed feeds.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Adds an accent border and a Following badge so artists you follow stand out in mixed feeds."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "フォロー中の絵師の作品にアクセント色の枠と「フォロー中」バッジを付けて、混在フィード内で識別しやすくします。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "为已关注画师的作品加上强调色边框与「已关注」徽标，让其在混合 feed 中一目了然。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "為已追蹤畫师的作品加上强調色邊框與「已追蹤」徽標，讓其在混合 feed 中一目了然。"
          }
        }
      }
    },
