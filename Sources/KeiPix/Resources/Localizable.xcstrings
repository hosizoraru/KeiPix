    "Keep ArtworkDownloadStore.markCompleted wired through DownloadCompletionNotifier so a finished download still hands off to UNUserNotificationCenter.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep ArtworkDownloadStore.markCompleted wired through DownloadCompletionNotifier so a finished download still hands off to UNUserNotificationCenter."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ArtworkDownloadStore.markCompleted を DownloadCompletionNotifier 経由で UNUserNotificationCenter に渡し、ダウンロード完了時の通知が途切れないようにしてください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "保持 ArtworkDownloadStore.markCompleted 经由 DownloadCompletionNotifier 转交给 UNUserNotificationCenter，以便完成的下载仍会触发通知。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "保持 ArtworkDownloadStore.markCompleted 經由 DownloadCompletionNotifier 轉交給 UNUserNotificationCenter，以便完成的下載仍會觸發通知。"
          }
        }
      }
    },
    "Keep DownloadQueueView's quickLookURL binding and focus-driven Space handler covered so Apple's preview panel never falls back to a third-party fallback.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep DownloadQueueView's quickLookURL binding and focus-driven Space handler covered so Apple's preview panel never falls back to a third-party fallback."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "DownloadQueueView の quickLookURL バインディングとフォーカス駆動のスペースキー処理をカバレッジに含め、Apple のプレビューパネルがサードパーティ実装にフォールバックしないようにしてください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "持续覆盖 DownloadQueueView 的 quickLookURL 绑定与基于焦点的空格键处理，确保 Apple 的预览面板不会回退到第三方实现。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "持續覆盖 DownloadQueueView 的 quickLookURL 绑定與基於焦點的空格鍵處理，確保 Apple 的預覽面板不會回退到第三方實現。"
          }
        }
      }
    },
    "Keep DownloadThroughputSampler wired through ArtworkDownloadStore.download(_:sourceURLs:) and reset on pause / cancel / complete so the speedometer never lies.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep DownloadThroughputSampler wired through ArtworkDownloadStore.download(_:sourceURLs:) and reset on pause / cancel / complete so the speedometer never lies."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "DownloadThroughputSampler を ArtworkDownloadStore.download(_:sourceURLs:) に接続し、一時停止／キャンセル／完了時にリセットして、速度計が誤った値を示さないようにしてください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "保持 DownloadThroughputSampler 接入 ArtworkDownloadStore.download(_:sourceURLs:)，并在暂停/取消/完成时重置，避免速度指示失真。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "保持 DownloadThroughputSampler 接入 ArtworkDownloadStore.download(_:sourceURLs:)，並在暫停/取消/完成時重置，避免速度指示失真。"
          }
        }
      }
    },
    "Keep PixivLinkDropPayload and the artwork drag URL covered so a future ProxyRepresentation refactor doesn't silently break Finder drops.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep PixivLinkDropPayload and the artwork drag URL covered so a future ProxyRepresentation refactor doesn't silently break Finder drops."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "将来 ProxyRepresentation をリファクタリングしても Finder へのドロップが壊れないよう、PixivLinkDropPayload と作品ドラッグ URL をカバレッジに含めてください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在覆盖中保留 PixivLinkDropPayload 与作品拖拽 URL，避免未来的 ProxyRepresentation 重构悄然破坏访达拖放。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在覆盖中保留 PixivLinkDropPayload 與作品拖拽 URL，避免未來的 ProxyRepresentation 重構悄然破壞訪達拖放。"
          }
        }
      }
    },
    "Keep ProxyConfiguration.loadFromUserDefaults wired through PixivAPI.init and ImagePipeline.init so the proxy mode never silently regresses to system on launch.": {
