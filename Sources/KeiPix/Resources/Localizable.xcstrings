    "Pixiv ships every illust at three sizes. Pick the rung that matches your bandwidth — Medium loads fastest, Original is the source asset.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pixiv ships every illust at three sizes. Pick the rung that matches your bandwidth — Medium loads fastest, Original is the source asset."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Pixiv は各作品を 3 段階のサイズで配信しています。回線に合わせて選んでください — 中が最速、オリジナルが原本です。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Pixiv 为每张作品提供三档尺寸，按带宽与画质需求选择 — 中等加载最快，原图为原始素材。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Pixiv 為每张作品提供三档尺寸，按帶寬與畫质需求選擇 — 中等載入最快，原圖為原始素材。"
          }
        }
      }
    },
    "Pixiv sync covers muted tags and creators. Local muted artworks stay on this Mac.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pixiv sync covers muted tags and creators. Local muted artworks stay on this Mac."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Pixiv同期はミュートタグとクリエイターをカバー。ローカルミュート作品はこのMacに残ります"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Pixiv 同步包含屏蔽标签和创作者，本地屏蔽作品会保留在这台 Mac。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Pixiv 同步包含封鎖標籤和創作者，本地封鎖作品會保留在這台 Mac。"
          }
        }
      }
    },
    "Pixiv-link drops resolve through Transferable on every drop surface, and completed downloads + artwork cards drag out as native file or URL payloads.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pixiv-link drops resolve through Transferable on every drop surface, and completed downloads + artwork cards drag out as native file or URL payloads."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "すべてのドロップ領域で Pixiv リンクを Transferable 経由で解決し、ダウンロード済みファイルや作品カードはネイティブのファイルまたは URL ペイロードとしてドラッグできます。"
          }
        },
        "zh-Hans": {
