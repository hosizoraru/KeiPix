          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "远端写入或破坏性动作会持续显示在验收清单中，直到测试账号或明确授权覆盖。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
