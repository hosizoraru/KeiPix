    "Paste a Pixiv refresh token exported from another client. KeiPix refreshes it once, saves the new session in secure local storage, and switches to the imported account.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Paste a Pixiv refresh token exported from another client. KeiPix refreshes it once, saves the new session in secure local storage, and switches to the imported account."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "他のクライアントからエクスポートしたPixivリフレッシュトークンを貼り付け。KeiPixは1回更新し、新しいセッションをセキュアローカルストレージに保存してインポートしたアカウントに切り替えます"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "粘贴从其他客户端导出的 Pixiv refresh token。KeiPix 会刷新一次，将新的登录态保存到安全本地存储，并切换到导入账号。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "貼上從其他客戶端導出的 Pixiv refresh token。KeiPix 會刷新一次，將新的登入態保存到安全本地存儲，並切換到導入帳號。"
          }
        }
      }
    },
    "No Pixiv Web cookies were found yet. Sign in on the page first, then save again.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No Pixiv Web cookies were found yet. Sign in on the page first, then save again."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Pixiv Web cookie がまだ見つかりません。先にページでログインしてから、もう一度保存してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "还没有找到 Pixiv Web cookie。请先在页面里登录，然后再次保存。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "還沒有找到 Pixiv Web cookie。請先在頁面裡登入，然後再次保存。"
          }
        }
      }
    },
    "Not connected": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Not connected"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "未接続"
