    "The interface is tuned separately for Mac windows, iPad multitasking, and iPhone-size layouts while sharing one codebase.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The interface is tuned separately for Mac windows, iPad multitasking, and iPhone-size layouts while sharing one codebase."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "インターフェイスは 1 つのコードベースを共有しながら、Mac ウインドウ、iPad のマルチタスク、iPhone サイズのレイアウトごとに調整されています。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "界面会分别针对 Mac 窗口、iPad 多任务和 iPhone 尺寸布局调整，同时共享同一套代码。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "介面會分別針對 Mac 視窗、iPad 多工與 iPhone 尺寸版面調整，同時共用同一套程式碼。"
          }
        }
      }
    },
    "The project is developed in the open on GitHub. File issues, inspect commits, or review the Apache-2.0 source from the repository.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The project is developed in the open on GitHub. File issues, inspect commits, or review the Apache-2.0 source from the repository."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このプロジェクトは GitHub 上で公開開発されています。リポジトリから Issue の作成、コミット確認、Apache-2.0 ソースのレビューができます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "项目在 GitHub 上开放开发。你可以在仓库中提交问题、查看提交，或审阅 Apache-2.0 源码。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "專案在 GitHub 上公開開發。你可以在倉庫中回報問題、查看提交，或審閱 Apache-2.0 原始碼。"
          }
        }
      }
    },
