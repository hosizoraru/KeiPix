        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "未連接"
          }
        }
      }
    },
    "Pixiv Web login cookie was not found. Sign in on Pixiv Web first.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pixiv Web login cookie was not found. Sign in on Pixiv Web first."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Pixiv Web のログイン cookie が見つかりません。先に Pixiv Web でログインしてください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "没有找到 Pixiv Web 登录 cookie。请先登录 Pixiv Web。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "沒有找到 Pixiv Web 登入 cookie。請先登入 Pixiv Web。"
          }
        }
      }
    },
    "Pixiv Web did not report a signed-in session. Sign in on the page first, then save again.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pixiv Web did not report a signed-in session. Sign in on the page first, then save again."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Pixiv Web がログイン済みセッションを返しませんでした。ページでログインしてから、もう一度保存してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Pixiv Web 没有确认这是已登录会话。请先在页面里登录，然后再保存。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Pixiv Web 沒有確認這是已登入會話。請先在頁面裡登入，然後再儲存。"
          }
        }
      }
    },
    "Pixiv Web session connection failed.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pixiv Web session connection failed."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Pixiv Web セッションの接続に失敗しました。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Pixiv Web 会话连接失败。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Pixiv Web 會話連接失敗。"
          }
        }
      }
    },
    "Required only for Pixiv Web-only features such as saved collections. KeiPix stores this separately from the app API token and never imports browser cookies automatically.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Required only for Pixiv Web-only features such as saved collections. KeiPix stores this separately from the app API token and never imports browser cookies automatically."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "保存したコレクションなど Pixiv Web 専用機能だけに必要です。KeiPix はアプリ API トークンとは別に保存し、ブラウザ cookie を自動インポートしません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "只用于收藏的珍藏册等 Pixiv Web 专属功能。KeiPix 会把它和 App API token 分开保存，也不会自动导入浏览器 cookie。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "只用於收藏的珍藏冊等 Pixiv Web 專屬功能。KeiPix 會把它和 App API token 分開保存，也不會自動導入瀏覽器 cookie。"
          }
        }
      }
    },
    "Sign in on Pixiv Web, then save this session so KeiPix can sync Web-only collection lists.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sign in on Pixiv Web, then save this session so KeiPix can sync Web-only collection lists."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
